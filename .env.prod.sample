# App
ENVIRONMENT=production
# Public app port exposed by Nginx on the host.
APP_PORT=80

# Optional image overrides (useful when Docker Hub is flaky/blocked)
# Example mirror: NODE_IMAGE=docker.m.daocloud.io/library/node:25-alpine
NODE_IMAGE=node:25-alpine

# Postgres (compose service)
DB_HOST=db
DB_PORT=5432
DB_NAME=bazaaryar_prod
DB_USER=bazaaryar
DB_PASSWORD=change-me
DB_SSL_MODE=disable
POSTGRES_DB=bazaaryar_prod
POSTGRES_USER=bazaaryar
POSTGRES_PASSWORD=change-me

# Optional: overrides the discrete DB_* settings
# DATABASE_URL=postgresql://user:pass:5432/db?sslmode=require

# Phoenix
PHOENIX_ENABLED=true
PHOENIX_PROJECT_NAME=bazaaryar-agent
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
PHOENIX_TAG=latest
PHOENIX_UI_PORT=6006
PHOENIX_WORKING_DIR=/mnt/data

# CORS Origins (comma-separated)
# Example: FRONTEND_ORIGINS=https://app.example.com,https://www.example.com
FRONTEND_ORIGINS=http://localhost

# OpenAI-Compatible
OPENAILIKE_MODEL=gpt-4.1-mini
OPENAILIKE_API_KEY=
OPENAILIKE_BASE_URL=
OPENAILIKE_TEMPERATURE=1.0
OPENAILIKE_REASONING_EFFORT=medium
OPENAILIKE_REASONING_ENABLED=true

# Uploads
UPLOAD_STORAGE_DIR=server/storage/uploads
UPLOAD_MAX_SIZE_BYTES=15728640

# Sandbox configs
SANDBOX_TOOL_ENABLED=true
SANDBOX_DOCKER_IMAGE=bazaaryar-python-sandbox:latest
SANDBOX_DOCKER_BIN=docker
# Must be an absolute host path. It is mounted into server with the same path
# and used as Docker bind source for sandbox containers.
SANDBOX_WORKSPACE_ROOT=/tmp/bazaaryar-sandbox
SANDBOX_MAX_RUNTIME_SECONDS=90
SANDBOX_MAX_MEMORY_MB=1024
SANDBOX_MAX_CPU=1.0
SANDBOX_MAX_ARTIFACTS=8
SANDBOX_MAX_ARTIFACT_BYTES=10485760
SANDBOX_MAX_CODE_CHARS=20000
SANDBOX_PERSIST_SESSIONS=true
SANDBOX_SESSION_IDLE_TTL_SECONDS=43200
SANDBOX_SESSION_POLL_INTERVAL_MS=100
SANDBOX_SESSION_QUEUE_WAIT_TIMEOUT_SECONDS=180
SANDBOX_SESSION_SWEEP_INTERVAL_SECONDS=60

# Frontend public vars (baked into the web build)
# Leave NEXT_PUBLIC_API_BASE_URL empty to use same-origin requests via Nginx.
# Set NEXT_PUBLIC_PHOENIX_URL to expose the Phoenix button in UI.
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_PHOENIX_URL=
